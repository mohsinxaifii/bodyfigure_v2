{% doc %}
  @prompt
    a block that lists contact details
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-details-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-contact-details__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-contact-details__list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-contact-details__item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: {{ block.settings.icon_spacing }}px;
  }

  .ai-contact-details__icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
    margin-top: 2px;
  }

  .ai-contact-details__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-contact-details__content-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-contact-details__label-{{ ai_gen_id }} {
    display: block;
    font-weight: 600;
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    margin-bottom: 4px;
  }

  .ai-contact-details__value-{{ ai_gen_id }} {
    display: block;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
  }

  .ai-contact-details__link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .ai-contact-details__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
    text-decoration: underline;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-details-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-contact-details-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-contact-details__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <ul class="ai-contact-details__list-{{ ai_gen_id }}">
    {% if block.settings.show_phone and block.settings.phone != blank %}
      <li class="ai-contact-details__item-{{ ai_gen_id }}">
        <div class="ai-contact-details__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
        </div>
        <div class="ai-contact-details__content-{{ ai_gen_id }}">
          {% if block.settings.phone_label != blank %}
            <span class="ai-contact-details__label-{{ ai_gen_id }}">{{ block.settings.phone_label }}</span>
          {% endif %}
          <a href="tel:{{ block.settings.phone }}" class="ai-contact-details__value-{{ ai_gen_id }} ai-contact-details__link-{{ ai_gen_id }}">
            {{ block.settings.phone }}
          </a>
        </div>
      </li>
    {% endif %}

    {% if block.settings.show_email and block.settings.email != blank %}
      <li class="ai-contact-details__item-{{ ai_gen_id }}">
        <div class="ai-contact-details__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
        </div>
        <div class="ai-contact-details__content-{{ ai_gen_id }}">
          {% if block.settings.email_label != blank %}
            <span class="ai-contact-details__label-{{ ai_gen_id }}">{{ block.settings.email_label }}</span>
          {% endif %}
          <a href="mailto:{{ block.settings.email }}" class="ai-contact-details__value-{{ ai_gen_id }} ai-contact-details__link-{{ ai_gen_id }}">
            {{ block.settings.email }}
          </a>
        </div>
      </li>
    {% endif %}

    {% if block.settings.show_address and block.settings.address != blank %}
      <li class="ai-contact-details__item-{{ ai_gen_id }}">
        <div class="ai-contact-details__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </div>
        <div class="ai-contact-details__content-{{ ai_gen_id }}">
          {% if block.settings.address_label != blank %}
            <span class="ai-contact-details__label-{{ ai_gen_id }}">{{ block.settings.address_label }}</span>
          {% endif %}
          <span class="ai-contact-details__value-{{ ai_gen_id }}">{{ block.settings.address }}</span>
        </div>
      </li>
    {% endif %}

    {% if block.settings.show_hours and block.settings.hours != blank %}
      <li class="ai-contact-details__item-{{ ai_gen_id }}">
        <div class="ai-contact-details__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </div>
        <div class="ai-contact-details__content-{{ ai_gen_id }}">
          {% if block.settings.hours_label != blank %}
            <span class="ai-contact-details__label-{{ ai_gen_id }}">{{ block.settings.hours_label }}</span>
          {% endif %}
          <span class="ai-contact-details__value-{{ ai_gen_id }}">{{ block.settings.hours }}</span>
        </div>
      </li>
    {% endif %}
  </ul>
</div>

{% schema %}
{
  "name": "Contact details",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get in touch"
    },
    {
      "type": "header",
      "content": "Phone"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Show phone",
      "default": true
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Label",
      "default": "Phone"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "+1 (555) 123-4567"
    },
    {
      "type": "header",
      "content": "Email"
    },
    {
      "type": "checkbox",
      "id": "show_email",
      "label": "Show email",
      "default": true
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "contact@example.com"
    },
    {
      "type": "header",
      "content": "Address"
    },
    {
      "type": "checkbox",
      "id": "show_address",
      "label": "Show address",
      "default": true
    },
    {
      "type": "text",
      "id": "address_label",
      "label": "Label",
      "default": "Address"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "123 Main Street, City, State 12345"
    },
    {
      "type": "header",
      "content": "Business hours"
    },
    {
      "type": "checkbox",
      "id": "show_hours",
      "label": "Show hours",
      "default": true
    },
    {
      "type": "text",
      "id": "hours_label",
      "label": "Label",
      "default": "Hours"
    },
    {
      "type": "textarea",
      "id": "hours",
      "label": "Business hours",
      "default": "Mon-Fri: 9am - 6pm"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Heading spacing",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "item_spacing",
      "label": "Item spacing",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "icon_spacing",
      "label": "Icon spacing",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#3d3326"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Labels",
      "default": "#3d3326"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#3d3326"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icons",
      "default": "#3d3326"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Links",
      "default": "#3d3326"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Links hover",
      "default": "#713f50"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Contact details"
    }
  ]
}
{% endschema %}
