{% doc %}
  @prompt
    I need a bento collage of images that has a lightbox feature 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bento-collage-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.spacing }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-bento-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(3, 200px);
    gap: {{ block.settings.gap }}px;
  }

  .ai-bento-item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .ai-bento-item-{{ ai_gen_id }}:hover {
    transform: scale(1.02);
  }

  .ai-bento-item-{{ ai_gen_id }}--1 {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }

  .ai-bento-item-{{ ai_gen_id }}--2 {
    grid-column: 3 / 5;
    grid-row: 1 / 2;
  }

  .ai-bento-item-{{ ai_gen_id }}--3 {
    grid-column: 3 / 4;
    grid-row: 2 / 4;
  }

  .ai-bento-item-{{ ai_gen_id }}--4 {
    grid-column: 4 / 5;
    grid-row: 2 / 4;
  }

  .ai-bento-item-{{ ai_gen_id }}--5 {
    grid-column: 1 / 2;
    grid-row: 3 / 4;
  }

  .ai-bento-item-{{ ai_gen_id }}--6 {
    grid-column: 2 / 3;
    grid-row: 3 / 4;
  }

  .ai-bento-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-bento-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-bento-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-bento-lightbox-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.9);
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-bento-lightbox-{{ ai_gen_id }}.active {
    display: flex;
    opacity: 1;
  }

  .ai-bento-lightbox-content-{{ ai_gen_id }} {
    position: relative;
    max-width: 90%;
    max-height: 90%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-bento-lightbox-image-{{ ai_gen_id }} {
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
  }

  .ai-bento-lightbox-close-{{ ai_gen_id }} {
    position: absolute;
    top: 20px;
    right: 20px;
    background: {{ block.settings.close_button_color }};
    color: {{ block.settings.close_button_text_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10000;
    transition: transform 0.2s ease;
  }

  .ai-bento-lightbox-close-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
  }

  .ai-bento-lightbox-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: {{ block.settings.nav_button_color }};
    color: {{ block.settings.nav_button_text_color }};
    border: none;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease;
  }

  .ai-bento-lightbox-nav-{{ ai_gen_id }}:hover {
    transform: translateY(-50%) scale(1.1);
  }

  .ai-bento-lightbox-prev-{{ ai_gen_id }} {
    left: 20px;
  }

  .ai-bento-lightbox-next-{{ ai_gen_id }} {
    right: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-bento-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(4, 150px);
    }

    .ai-bento-item-{{ ai_gen_id }}--1 {
      grid-column: 1 / 3;
      grid-row: 1 / 3;
    }

    .ai-bento-item-{{ ai_gen_id }}--2 {
      grid-column: 1 / 2;
      grid-row: 3 / 4;
    }

    .ai-bento-item-{{ ai_gen_id }}--3 {
      grid-column: 2 / 3;
      grid-row: 3 / 4;
    }

    .ai-bento-item-{{ ai_gen_id }}--4 {
      grid-column: 1 / 2;
      grid-row: 4 / 5;
    }

    .ai-bento-item-{{ ai_gen_id }}--5 {
      grid-column: 2 / 3;
      grid-row: 4 / 5;
    }

    .ai-bento-item-{{ ai_gen_id }}--6 {
      display: none;
    }
  }
{% endstyle %}

<bento-collage-{{ ai_gen_id }} class="ai-bento-collage-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-bento-grid-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign image = block.settings[image_key]
      %}
      <div class="ai-bento-item-{{ ai_gen_id }} ai-bento-item-{{ ai_gen_id }}--{{ i }}" data-index="{{ i }}">
        {% if image %}
          <img
            src="{{ image | image_url: width: 800 }}"
            alt="{{ image.alt | escape }}"
            loading="lazy"
            width="{{ image.width }}"
            height="{{ image.height }}"
            class="ai-bento-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-bento-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  <div class="ai-bento-lightbox-{{ ai_gen_id }}">
    <button class="ai-bento-lightbox-close-{{ ai_gen_id }}" aria-label="Close lightbox">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <button class="ai-bento-lightbox-nav-{{ ai_gen_id }} ai-bento-lightbox-prev-{{ ai_gen_id }}" aria-label="Previous image">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>
    <div class="ai-bento-lightbox-content-{{ ai_gen_id }}">
      <img src="" alt="" class="ai-bento-lightbox-image-{{ ai_gen_id }}">
    </div>
    <button class="ai-bento-lightbox-nav-{{ ai_gen_id }} ai-bento-lightbox-next-{{ ai_gen_id }}" aria-label="Next image">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</bento-collage-{{ ai_gen_id }}>

<script>
  (function() {
    class BentoCollage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.images = [];
      }

      connectedCallback() {
        this.items = this.querySelectorAll('.ai-bento-item-{{ ai_gen_id }}');
        this.lightbox = this.querySelector('.ai-bento-lightbox-{{ ai_gen_id }}');
        this.lightboxImage = this.querySelector('.ai-bento-lightbox-image-{{ ai_gen_id }}');
        this.closeButton = this.querySelector('.ai-bento-lightbox-close-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-bento-lightbox-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-bento-lightbox-next-{{ ai_gen_id }}');

        this.collectImages();
        this.setupEventListeners();
      }

      collectImages() {
        this.items.forEach((item) => {
          const img = item.querySelector('.ai-bento-image-{{ ai_gen_id }}');
          if (img) {
            this.images.push({
              src: img.src,
              alt: img.alt
            });
          }
        });
      }

      setupEventListeners() {
        this.items.forEach((item, index) => {
          const img = item.querySelector('.ai-bento-image-{{ ai_gen_id }}');
          if (img) {
            item.addEventListener('click', () => {
              this.openLightbox(index);
            });
          }
        });

        this.closeButton.addEventListener('click', () => {
          this.closeLightbox();
        });

        this.lightbox.addEventListener('click', (e) => {
          if (e.target === this.lightbox) {
            this.closeLightbox();
          }
        });

        this.prevButton.addEventListener('click', () => {
          this.showPrevious();
        });

        this.nextButton.addEventListener('click', () => {
          this.showNext();
        });

        document.addEventListener('keydown', (e) => {
          if (!this.lightbox.classList.contains('active')) return;

          if (e.key === 'Escape') {
            this.closeLightbox();
          } else if (e.key === 'ArrowLeft') {
            this.showPrevious();
          } else if (e.key === 'ArrowRight') {
            this.showNext();
          }
        });
      }

      openLightbox(index) {
        if (this.images.length === 0) return;
        this.currentIndex = index;
        this.updateLightboxImage();
        this.lightbox.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      closeLightbox() {
        this.lightbox.classList.remove('active');
        document.body.style.overflow = '';
      }

      showPrevious() {
        this.currentIndex = (this.currentIndex - 1 + this.images.length) % this.images.length;
        this.updateLightboxImage();
      }

      showNext() {
        this.currentIndex = (this.currentIndex + 1) % this.images.length;
        this.updateLightboxImage();
      }

      updateLightboxImage() {
        const image = this.images[this.currentIndex];
        this.lightboxImage.src = image.src;
        this.lightboxImage.alt = image.alt;
      }
    }

    customElements.define('bento-collage-{{ ai_gen_id }}', BentoCollage{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Bento image collage",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1 (large)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Image 4"
    },
    {
      "type": "image_picker",
      "id": "image_5",
      "label": "Image 5"
    },
    {
      "type": "image_picker",
      "id": "image_6",
      "label": "Image 6"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between images",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Lightbox"
    },
    {
      "type": "color",
      "id": "close_button_color",
      "label": "Close button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "close_button_text_color",
      "label": "Close button icon",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "nav_button_color",
      "label": "Navigation button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "nav_button_text_color",
      "label": "Navigation button icon",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Bento image collage"
    }
  ]
}
{% endschema %}