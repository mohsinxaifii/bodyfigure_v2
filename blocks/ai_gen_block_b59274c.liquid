{% doc %}
  @prompt
    I need a timeline with 10 events.
    the format will be 
    date
    title
    description
    image gallery 3 imageswith lightbox feature.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-timeline-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 20px;
  }

  .ai-timeline-container-{{ ai_gen_id }} {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-timeline-line-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background-color: {{ block.settings.line_color }};
    transform: translateX(-50%);
  }

  .ai-timeline-event-{{ ai_gen_id }} {
    position: relative;
    margin-bottom: 60px;
    display: flex;
    align-items: flex-start;
    gap: 40px;
  }

  .ai-timeline-event-{{ ai_gen_id }}:nth-child(odd) {
    flex-direction: row;
  }

  .ai-timeline-event-{{ ai_gen_id }}:nth-child(even) {
    flex-direction: row-reverse;
  }

  .ai-timeline-content-{{ ai_gen_id }} {
    flex: 1;
    padding: 20px;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-timeline-event-{{ ai_gen_id }}:nth-child(odd) .ai-timeline-content-{{ ai_gen_id }} {
    text-align: right;
  }

  .ai-timeline-event-{{ ai_gen_id }}:nth-child(even) .ai-timeline-content-{{ ai_gen_id }} {
    text-align: left;
  }

  .ai-timeline-date-{{ ai_gen_id }} {
    font-size: {{ block.settings.date_font_size }}px;
    color: {{ block.settings.date_color }};
    margin-bottom: 8px;
    font-weight: 600;
  }

  .ai-timeline-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin-bottom: 12px;
    font-weight: 700;
  }

  .ai-timeline-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .ai-timeline-gallery-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-top: 16px;
  }

  .ai-timeline-gallery-item-{{ ai_gen_id }} {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .ai-timeline-gallery-item-{{ ai_gen_id }}:hover {
    transform: scale(1.05);
  }

  .ai-timeline-gallery-item-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-timeline-gallery-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-timeline-gallery-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-timeline-dot-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 30px;
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    background-color: {{ block.settings.dot_color }};
    border: 4px solid {{ block.settings.card_background }};
    border-radius: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }

  .ai-timeline-lightbox-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.9);
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }

  .ai-timeline-lightbox-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-timeline-lightbox-content-{{ ai_gen_id }} {
    position: relative;
    max-width: 90%;
    max-height: 90%;
  }

  .ai-timeline-lightbox-image-{{ ai_gen_id }} {
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
  }

  .ai-timeline-lightbox-close-{{ ai_gen_id }} {
    position: absolute;
    top: -40px;
    right: 0;
    background: none;
    border: none;
    color: white;
    font-size: 32px;
    cursor: pointer;
    padding: 8px;
    line-height: 1;
  }

  .ai-timeline-lightbox-close-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  @media screen and (max-width: 768px) {
    .ai-timeline-line-{{ ai_gen_id }} {
      left: 20px;
    }

    .ai-timeline-event-{{ ai_gen_id }},
    .ai-timeline-event-{{ ai_gen_id }}:nth-child(odd),
    .ai-timeline-event-{{ ai_gen_id }}:nth-child(even) {
      flex-direction: column;
      padding-left: 50px;
    }

    .ai-timeline-content-{{ ai_gen_id }},
    .ai-timeline-event-{{ ai_gen_id }}:nth-child(odd) .ai-timeline-content-{{ ai_gen_id }},
    .ai-timeline-event-{{ ai_gen_id }}:nth-child(even) .ai-timeline-content-{{ ai_gen_id }} {
      text-align: left;
    }

    .ai-timeline-dot-{{ ai_gen_id }} {
      left: 20px;
    }
  }
{% endstyle %}

<timeline-block-{{ ai_gen_id }} class="ai-timeline-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-timeline-container-{{ ai_gen_id }}">
    <div class="ai-timeline-line-{{ ai_gen_id }}"></div>

    {% for i in (1..10) %}
      {% liquid
        assign date_key = 'event_' | append: i | append: '_date'
        assign title_key = 'event_' | append: i | append: '_title'
        assign description_key = 'event_' | append: i | append: '_description'
        assign image1_key = 'event_' | append: i | append: '_image_1'
        assign image2_key = 'event_' | append: i | append: '_image_2'
        assign image3_key = 'event_' | append: i | append: '_image_3'

        assign event_date = block.settings[date_key]
        assign event_title = block.settings[title_key]
        assign event_description = block.settings[description_key]
        assign event_image_1 = block.settings[image1_key]
        assign event_image_2 = block.settings[image2_key]
        assign event_image_3 = block.settings[image3_key]
      %}

      <div class="ai-timeline-event-{{ ai_gen_id }}">
        <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>
        <div class="ai-timeline-content-{{ ai_gen_id }}">
          {% if event_date != blank %}
            <div class="ai-timeline-date-{{ ai_gen_id }}">{{ event_date }}</div>
          {% endif %}

          {% if event_title != blank %}
            <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ event_title }}</h3>
          {% endif %}

          {% if event_description != blank %}
            <div class="ai-timeline-description-{{ ai_gen_id }}">{{ event_description }}</div>
          {% endif %}

          <div class="ai-timeline-gallery-{{ ai_gen_id }}">
            {% if event_image_1 %}
              <div class="ai-timeline-gallery-item-{{ ai_gen_id }}" data-image-url="{{ event_image_1 | image_url: width: 1200 }}">
                <img
                  src="{{ event_image_1 | image_url: width: 400 }}"
                  alt="{{ event_image_1.alt | escape }}"
                  loading="lazy"
                  width="400"
                  height="400"
                >
              </div>
            {% else %}
              <div class="ai-timeline-gallery-item-{{ ai_gen_id }}">
                <div class="ai-timeline-gallery-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              </div>
            {% endif %}

            {% if event_image_2 %}
              <div class="ai-timeline-gallery-item-{{ ai_gen_id }}" data-image-url="{{ event_image_2 | image_url: width: 1200 }}">
                <img
                  src="{{ event_image_2 | image_url: width: 400 }}"
                  alt="{{ event_image_2.alt | escape }}"
                  loading="lazy"
                  width="400"
                  height="400"
                >
              </div>
            {% else %}
              <div class="ai-timeline-gallery-item-{{ ai_gen_id }}">
                <div class="ai-timeline-gallery-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              </div>
            {% endif %}

            {% if event_image_3 %}
              <div class="ai-timeline-gallery-item-{{ ai_gen_id }}" data-image-url="{{ event_image_3 | image_url: width: 1200 }}">
                <img
                  src="{{ event_image_3 | image_url: width: 400 }}"
                  alt="{{ event_image_3.alt | escape }}"
                  loading="lazy"
                  width="400"
                  height="400"
                >
              </div>
            {% else %}
              <div class="ai-timeline-gallery-item-{{ ai_gen_id }}">
                <div class="ai-timeline-gallery-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  <div class="ai-timeline-lightbox-{{ ai_gen_id }}">
    <div class="ai-timeline-lightbox-content-{{ ai_gen_id }}">
      <button class="ai-timeline-lightbox-close-{{ ai_gen_id }}" aria-label="Close lightbox">&times;</button>
      <img class="ai-timeline-lightbox-image-{{ ai_gen_id }}" src="" alt="">
    </div>
  </div>
</timeline-block-{{ ai_gen_id }}>

<script>
  (function() {
    class TimelineBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.lightbox = this.querySelector('.ai-timeline-lightbox-{{ ai_gen_id }}');
        this.lightboxImage = this.querySelector('.ai-timeline-lightbox-image-{{ ai_gen_id }}');
        this.closeButton = this.querySelector('.ai-timeline-lightbox-close-{{ ai_gen_id }}');
        this.galleryItems = this.querySelectorAll('.ai-timeline-gallery-item-{{ ai_gen_id }}');

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.galleryItems.forEach((item) => {
          item.addEventListener('click', () => {
            const imageUrl = item.getAttribute('data-image-url');
            if (imageUrl) {
              this.openLightbox(imageUrl);
            }
          });
        });

        this.closeButton.addEventListener('click', () => {
          this.closeLightbox();
        });

        this.lightbox.addEventListener('click', (e) => {
          if (e.target === this.lightbox) {
            this.closeLightbox();
          }
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.lightbox.classList.contains('active')) {
            this.closeLightbox();
          }
        });
      }

      openLightbox(imageUrl) {
        this.lightboxImage.src = imageUrl;
        this.lightbox.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      closeLightbox() {
        this.lightbox.classList.remove('active');
        this.lightboxImage.src = '';
        document.body.style.overflow = '';
      }
    }

    customElements.define('timeline-block-{{ ai_gen_id }}', TimelineBlock{{ ai_gen_id }});
  })();
</script>

