{% doc %}
  @prompt
    this section needs to be a timeline
    
    February 28 - designing
    March 5 - launch with new marketing strategy print media
    , there should be a paragraph after each title
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-timeline-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 20px;
    display: block;
  }

  .ai-timeline-container-{{ ai_gen_id }} {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  .ai-timeline-line-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: {{ block.settings.line_width }}px;
    background-color: {{ block.settings.line_color }};
    transform: translateX(-50%);
  }

  .ai-timeline-item-{{ ai_gen_id }} {
    position: relative;
    margin-bottom: 60px;
    display: flex;
    align-items: center;
  }

  .ai-timeline-item-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-timeline-content-{{ ai_gen_id }} {
    width: calc(50% - 40px);
    padding: 20px;
    background-color: {{ block.settings.content_bg_color }};
    border-radius: {{ block.settings.content_border_radius }}px;
    border: {{ block.settings.content_border_width }}px solid {{ block.settings.content_border_color }};
  }

  .ai-timeline-item-{{ ai_gen_id }}:nth-child(odd) .ai-timeline-content-{{ ai_gen_id }} {
    margin-right: auto;
    text-align: right;
  }

  .ai-timeline-item-{{ ai_gen_id }}:nth-child(even) .ai-timeline-content-{{ ai_gen_id }} {
    margin-left: auto;
    text-align: left;
  }

  .ai-timeline-date-{{ ai_gen_id }} {
    font-size: {{ block.settings.date_font_size }}px;
    color: {{ block.settings.date_color }};
    font-weight: 600;
    margin-bottom: 8px;
  }

  .ai-timeline-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 8px 0;
  }

  .ai-timeline-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-timeline-dot-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 20px;
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    background-color: {{ block.settings.dot_color }};
    border: {{ block.settings.dot_border_width }}px solid {{ block.settings.dot_border_color }};
    border-radius: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }

  @media screen and (max-width: 749px) {
    .ai-timeline-line-{{ ai_gen_id }} {
      left: 20px;
    }

    .ai-timeline-item-{{ ai_gen_id }} {
      padding-left: 50px;
    }

    .ai-timeline-content-{{ ai_gen_id }} {
      width: 100%;
      text-align: left;
    }

    .ai-timeline-item-{{ ai_gen_id }}:nth-child(odd) .ai-timeline-content-{{ ai_gen_id }},
    .ai-timeline-item-{{ ai_gen_id }}:nth-child(even) .ai-timeline-content-{{ ai_gen_id }} {
      margin: 0;
      text-align: left;
    }

    .ai-timeline-dot-{{ ai_gen_id }} {
      left: 20px;
    }
  }
{% endstyle %}

<div class="ai-timeline-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-timeline-container-{{ ai_gen_id }}">
    <div class="ai-timeline-line-{{ ai_gen_id }}"></div>

    {% if block.settings.event_1_date != blank %}
      <div class="ai-timeline-item-{{ ai_gen_id }}">
        <div class="ai-timeline-content-{{ ai_gen_id }}">
          <div class="ai-timeline-date-{{ ai_gen_id }}">{{ block.settings.event_1_date }}</div>
          <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ block.settings.event_1_title }}</h3>
          {% if block.settings.event_1_description != blank %}
            <p class="ai-timeline-description-{{ ai_gen_id }}">{{ block.settings.event_1_description }}</p>
          {% endif %}
        </div>
        <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>
      </div>
    {% endif %}

    {% if block.settings.event_2_date != blank %}
      <div class="ai-timeline-item-{{ ai_gen_id }}">
        <div class="ai-timeline-content-{{ ai_gen_id }}">
          <div class="ai-timeline-date-{{ ai_gen_id }}">{{ block.settings.event_2_date }}</div>
          <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ block.settings.event_2_title }}</h3>
          {% if block.settings.event_2_description != blank %}
            <p class="ai-timeline-description-{{ ai_gen_id }}">{{ block.settings.event_2_description }}</p>
          {% endif %}
        </div>
        <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>
      </div>
    {% endif %}

    {% if block.settings.event_3_date != blank %}
      <div class="ai-timeline-item-{{ ai_gen_id }}">
        <div class="ai-timeline-content-{{ ai_gen_id }}">
          <div class="ai-timeline-date-{{ ai_gen_id }}">{{ block.settings.event_3_date }}</div>
          <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ block.settings.event_3_title }}</h3>
          {% if block.settings.event_3_description != blank %}
            <p class="ai-timeline-description-{{ ai_gen_id }}">{{ block.settings.event_3_description }}</p>
          {% endif %}
        </div>
        <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>
      </div>
    {% endif %}

    {% if block.settings.event_4_date != blank %}
      <div class="ai-timeline-item-{{ ai_gen_id }}">
        <div class="ai-timeline-content-{{ ai_gen_id }}">
          <div class="ai-timeline-date-{{ ai_gen_id }}">{{ block.settings.event_4_date }}</div>
          <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ block.settings.event_4_title }}</h3>
          {% if block.settings.event_4_description != blank %}
            <p class="ai-timeline-description-{{ ai_gen_id }}">{{ block.settings.event_4_description }}</p>
          {% endif %}
        </div>
        <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>
      </div>
    {% endif %}

    {% if block.settings.event_5_date != blank %}
      <div class="ai-timeline-item-{{ ai_gen_id }}">
        <div class="ai-timeline-content-{{ ai_gen_id }}">
          <div class="ai-timeline-date-{{ ai_gen_id }}">{{ block.settings.event_5_date }}</div>
          <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ block.settings.event_5_title }}</h3>
          {% if block.settings.event_5_description != blank %}
            <p class="ai-timeline-description-{{ ai_gen_id }}">{{ block.settings.event_5_description }}</p>
          {% endif %}
        </div>
        <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>
      </div>
    {% endif %}
  </div>
</div>

