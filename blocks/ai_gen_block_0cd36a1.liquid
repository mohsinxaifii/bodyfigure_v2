{% doc %}
  @prompt
    Create a vertical timeline section with exactly 10 milestone events. Each event should have a year/date, title, and brief description. Use placeholder content for a brand journey timeline (e.g., founding, first product launch, expansion milestones, awards, etc.). Style it with a clean, modern design that fits a dark, warm-toned aesthetic with connecting lines between events. add a photo gallery for each event.
    
    10 events please
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-timeline-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-timeline-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }

  .ai-timeline-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 60px;
  }

  .ai-timeline-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
  }

  .ai-timeline-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
  }

  .ai-timeline-line-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: {{ block.settings.line_width }}px;
    background-color: {{ block.settings.line_color }};
    transform: translateX(-50%);
  }

  .ai-timeline-events-{{ ai_gen_id }} {
    position: relative;
    padding: 40px 0;
  }

  .ai-timeline-event-{{ ai_gen_id }} {
    position: relative;
    margin-bottom: 80px;
    display: flex;
    align-items: flex-start;
    gap: 40px;
  }

  .ai-timeline-event-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-timeline-event-{{ ai_gen_id }}:nth-child(odd) {
    flex-direction: row;
  }

  .ai-timeline-event-{{ ai_gen_id }}:nth-child(even) {
    flex-direction: row-reverse;
  }

  .ai-timeline-content-{{ ai_gen_id }} {
    flex: 1;
    max-width: calc(50% - 40px);
  }

  .ai-timeline-event-{{ ai_gen_id }}:nth-child(odd) .ai-timeline-content-{{ ai_gen_id }} {
    text-align: right;
    padding-right: 20px;
  }

  .ai-timeline-event-{{ ai_gen_id }}:nth-child(even) .ai-timeline-content-{{ ai_gen_id }} {
    text-align: left;
    padding-left: 20px;
  }

  .ai-timeline-date-{{ ai_gen_id }} {
    font-size: {{ block.settings.date_size }}px;
    color: {{ block.settings.accent_color }};
    font-weight: 600;
    margin-bottom: 12px;
    display: block;
  }

  .ai-timeline-event-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.event_title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-timeline-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.85;
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .ai-timeline-marker-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.marker_size }}px;
    height: {{ block.settings.marker_size }}px;
    background-color: {{ block.settings.marker_color }};
    border: {{ block.settings.marker_border_width }}px solid {{ block.settings.marker_border_color }};
    border-radius: 50%;
    flex-shrink: 0;
    z-index: 2;
    box-shadow: 0 0 0 8px {{ block.settings.background_color }};
  }

  .ai-timeline-gallery-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 12px;
    margin-top: 16px;
  }

  .ai-timeline-gallery-item-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: {{ block.settings.placeholder_bg_color }};
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .ai-timeline-gallery-item-{{ ai_gen_id }}:hover {
    transform: scale(1.05);
  }

  .ai-timeline-gallery-item-{{ ai_gen_id }} img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-timeline-gallery-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-timeline-gallery-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  @media screen and (max-width: 768px) {
    .ai-timeline-line-{{ ai_gen_id }} {
      left: 20px;
    }

    .ai-timeline-event-{{ ai_gen_id }} {
      flex-direction: row !important;
      gap: 20px;
      margin-bottom: 60px;
    }

    .ai-timeline-content-{{ ai_gen_id }} {
      max-width: 100%;
      text-align: left !important;
      padding-left: 0 !important;
      padding-right: 0 !important;
    }

    .ai-timeline-marker-{{ ai_gen_id }} {
      position: absolute;
      left: 20px;
      transform: translateX(-50%);
    }

    .ai-timeline-content-{{ ai_gen_id }} {
      margin-left: 40px;
    }

    .ai-timeline-gallery-{{ ai_gen_id }} {
      grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
      gap: 8px;
    }
  }
{% endstyle %}

<brand-timeline-{{ ai_gen_id }}
  class="ai-timeline-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-timeline-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank or block.settings.section_subtitle != blank %}
      <div class="ai-timeline-header-{{ ai_gen_id }}">
        {% if block.settings.section_title != blank %}
          <h2 class="ai-timeline-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
        {% endif %}
        {% if block.settings.section_subtitle != blank %}
          <p class="ai-timeline-subtitle-{{ ai_gen_id }}">{{ block.settings.section_subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-timeline-events-{{ ai_gen_id }}">
      <div class="ai-timeline-line-{{ ai_gen_id }}"></div>

      {% for i in (1..10) %}
        {% liquid
          assign date_key = 'event_' | append: i | append: '_date'
          assign title_key = 'event_' | append: i | append: '_title'
          assign description_key = 'event_' | append: i | append: '_description'
          assign image1_key = 'event_' | append: i | append: '_image_1'
          assign image2_key = 'event_' | append: i | append: '_image_2'
          assign image3_key = 'event_' | append: i | append: '_image_3'

          assign event_date = block.settings[date_key]
          assign event_title = block.settings[title_key]
          assign event_description = block.settings[description_key]
          assign event_image_1 = block.settings[image1_key]
          assign event_image_2 = block.settings[image2_key]
          assign event_image_3 = block.settings[image3_key]
        %}

        <div class="ai-timeline-event-{{ ai_gen_id }}">
          <div class="ai-timeline-content-{{ ai_gen_id }}">
            {% if event_date != blank %}
              <span class="ai-timeline-date-{{ ai_gen_id }}">{{ event_date }}</span>
            {% endif %}
            {% if event_title != blank %}
              <h3 class="ai-timeline-event-title-{{ ai_gen_id }}">{{ event_title }}</h3>
            {% endif %}
            {% if event_description != blank %}
              <p class="ai-timeline-description-{{ ai_gen_id }}">{{ event_description }}</p>
            {% endif %}

            <div class="ai-timeline-gallery-{{ ai_gen_id }}">
              <div class="ai-timeline-gallery-item-{{ ai_gen_id }}">
                {% if event_image_1 %}
                  <img
                    src="{{ event_image_1 | image_url: width: 300 }}"
                    alt="{{ event_title | escape }}"
                    loading="lazy"
                    width="300"
                    height="300"
                  >
                {% else %}
                  <div class="ai-timeline-gallery-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-timeline-gallery-item-{{ ai_gen_id }}">
                {% if event_image_2 %}
                  <img
                    src="{{ event_image_2 | image_url: width: 300 }}"
                    alt="{{ event_title | escape }}"
                    loading="lazy"
                    width="300"
                    height="300"
                  >
                {% else %}
                  <div class="ai-timeline-gallery-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-timeline-gallery-item-{{ ai_gen_id }}">
                {% if event_image_3 %}
                  <img
                    src="{{ event_image_3 | image_url: width: 300 }}"
                    alt="{{ event_title | escape }}"
                    loading="lazy"
                    width="300"
                    height="300"
                  >
                {% else %}
                  <div class="ai-timeline-gallery-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
            </div>
          </div>

          <div class="ai-timeline-marker-{{ ai_gen_id }}"></div>
        </div>
      {% endfor %}
    </div>
  </div>
</brand-timeline-{{ ai_gen_id }}>

<script>
  (function() {
    class BrandTimeline{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupGalleryInteractions();
      }

      setupGalleryInteractions() {
        const galleryItems = this.querySelectorAll('.ai-timeline-gallery-item-{{ ai_gen_id }}');
        
        galleryItems.forEach(item => {
          item.addEventListener('click', function() {
            const img = this.querySelector('img');
            if (img) {
              window.open(img.src, '_blank');
            }
          });
        });
      }
    }

    customElements.define('brand-timeline-{{ ai_gen_id }}', BrandTimeline{{ ai_gen_id }});
  })();
</script>

