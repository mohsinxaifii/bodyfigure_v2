{% doc %}
  @prompt
        I need a timeline with 10 events.
        the format will be 
        date
        title
        description
        image gallery 3 images with lightbox feature.
    
    events 1,2,3,7,8 will have no image gallery.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-timeline-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 0;
  }

  .ai-timeline-container-{{ ai_gen_id }} {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-timeline-line-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background-color: {{ block.settings.line_color }};
    transform: translateX(-50%);
  }

  .ai-timeline-event-{{ ai_gen_id }} {
    position: relative;
    margin-bottom: 60px;
    display: flex;
    align-items: flex-start;
  }

  .ai-timeline-event-{{ ai_gen_id }}:nth-child(odd) {
    flex-direction: row;
  }

  .ai-timeline-event-{{ ai_gen_id }}:nth-child(even) {
    flex-direction: row-reverse;
  }

  .ai-timeline-content-{{ ai_gen_id }} {
    width: calc(50% - 40px);
    padding: 20px;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-timeline-event-{{ ai_gen_id }}:nth-child(odd) .ai-timeline-content-{{ ai_gen_id }} {
    text-align: right;
    margin-right: 40px;
  }

  .ai-timeline-event-{{ ai_gen_id }}:nth-child(even) .ai-timeline-content-{{ ai_gen_id }} {
    text-align: left;
    margin-left: 40px;
  }

  .ai-timeline-dot-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    background-color: {{ block.settings.dot_color }};
    border: 3px solid {{ block.settings.card_background }};
    border-radius: 50%;
    z-index: 2;
  }

  .ai-timeline-date-{{ ai_gen_id }} {
    font-size: {{ block.settings.date_font_size }}px;
    color: {{ block.settings.date_color }};
    margin-bottom: 10px;
    font-weight: 600;
  }

  .ai-timeline-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin-bottom: 10px;
    font-weight: 700;
  }

  .ai-timeline-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin-bottom: 15px;
  }

  .ai-timeline-gallery-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-top: 15px;
  }

  .ai-timeline-gallery-item-{{ ai_gen_id }} {
    position: relative;
    cursor: pointer;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    aspect-ratio: 1;
  }

  .ai-timeline-gallery-item-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-timeline-gallery-item-{{ ai_gen_id }}:hover img {
    transform: scale(1.05);
  }

  .ai-timeline-lightbox-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.9);
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }

  .ai-timeline-lightbox-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-timeline-lightbox-content-{{ ai_gen_id }} {
    position: relative;
    max-width: 90%;
    max-height: 90%;
  }

  .ai-timeline-lightbox-content-{{ ai_gen_id }} img {
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
  }

  .ai-timeline-lightbox-close-{{ ai_gen_id }} {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: none;
    color: #ffffff;
    font-size: 40px;
    cursor: pointer;
    z-index: 10000;
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-timeline-lightbox-close-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-timeline-lightbox-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.2);
    border: none;
    color: #ffffff;
    font-size: 30px;
    cursor: pointer;
    padding: 20px;
    z-index: 10000;
  }

  .ai-timeline-lightbox-nav-{{ ai_gen_id }}:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .ai-timeline-lightbox-prev-{{ ai_gen_id }} {
    left: 20px;
  }

  .ai-timeline-lightbox-next-{{ ai_gen_id }} {
    right: 20px;
  }

  @media screen and (max-width: 768px) {
    .ai-timeline-line-{{ ai_gen_id }} {
      left: 30px;
    }

    .ai-timeline-event-{{ ai_gen_id }},
    .ai-timeline-event-{{ ai_gen_id }}:nth-child(odd),
    .ai-timeline-event-{{ ai_gen_id }}:nth-child(even) {
      flex-direction: row;
    }

    .ai-timeline-content-{{ ai_gen_id }},
    .ai-timeline-event-{{ ai_gen_id }}:nth-child(odd) .ai-timeline-content-{{ ai_gen_id }},
    .ai-timeline-event-{{ ai_gen_id }}:nth-child(even) .ai-timeline-content-{{ ai_gen_id }} {
      width: calc(100% - 60px);
      margin-left: 60px;
      margin-right: 0;
      text-align: left;
    }

    .ai-timeline-dot-{{ ai_gen_id }} {
      left: 30px;
    }

    .ai-timeline-gallery-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstyle %}

<timeline-block-{{ ai_gen_id }} class="ai-timeline-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-timeline-container-{{ ai_gen_id }}">
    <div class="ai-timeline-line-{{ ai_gen_id }}"></div>

    {% for i in (1..10) %}
      {% liquid
        assign event_enabled_key = 'event_' | append: i | append: '_enabled'
        assign event_date_key = 'event_' | append: i | append: '_date'
        assign event_title_key = 'event_' | append: i | append: '_title'
        assign event_description_key = 'event_' | append: i | append: '_description'
        assign event_image1_key = 'event_' | append: i | append: '_image1'
        assign event_image2_key = 'event_' | append: i | append: '_image2'
        assign event_image3_key = 'event_' | append: i | append: '_image3'

        assign event_enabled = block.settings[event_enabled_key]
        assign event_date = block.settings[event_date_key]
        assign event_title = block.settings[event_title_key]
        assign event_description = block.settings[event_description_key]
        assign event_image1 = block.settings[event_image1_key]
        assign event_image2 = block.settings[event_image2_key]
        assign event_image3 = block.settings[event_image3_key]

        assign has_gallery = false
        if event_image1 != blank or event_image2 != blank or event_image3 != blank
          assign has_gallery = true
        endif
      %}

      {% if event_enabled %}
        <div class="ai-timeline-event-{{ ai_gen_id }}" data-event="{{ i }}">
          <div class="ai-timeline-content-{{ ai_gen_id }}">
            {% if event_date != blank %}
              <div class="ai-timeline-date-{{ ai_gen_id }}">{{ event_date }}</div>
            {% endif %}

            {% if event_title != blank %}
              <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ event_title }}</h3>
            {% endif %}

            {% if event_description != blank %}
              <div class="ai-timeline-description-{{ ai_gen_id }}">{{ event_description }}</div>
            {% endif %}

            {% if has_gallery %}
              <div class="ai-timeline-gallery-{{ ai_gen_id }}">
                {% if event_image1 != blank %}
                  <div class="ai-timeline-gallery-item-{{ ai_gen_id }}" data-image-index="0" data-event-id="{{ i }}">
                    <img
                      src="{{ event_image1 | image_url: width: 400 }}"
                      alt="{{ event_title | escape }}"
                      loading="lazy"
                      width="400"
                      height="400"
                    >
                  </div>
                {% endif %}

                {% if event_image2 != blank %}
                  <div class="ai-timeline-gallery-item-{{ ai_gen_id }}" data-image-index="1" data-event-id="{{ i }}">
                    <img
                      src="{{ event_image2 | image_url: width: 400 }}"
                      alt="{{ event_title | escape }}"
                      loading="lazy"
                      width="400"
                      height="400"
                    >
                  </div>
                {% endif %}

                {% if event_image3 != blank %}
                  <div class="ai-timeline-gallery-item-{{ ai_gen_id }}" data-image-index="2" data-event-id="{{ i }}">
                    <img
                      src="{{ event_image3 | image_url: width: 400 }}"
                      alt="{{ event_title | escape }}"
                      loading="lazy"
                      width="400"
                      height="400"
                    >
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </div>
          <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="ai-timeline-lightbox-{{ ai_gen_id }}" id="lightbox-{{ ai_gen_id }}">
    <button class="ai-timeline-lightbox-close-{{ ai_gen_id }}" aria-label="Close lightbox">&times;</button>
    <button class="ai-timeline-lightbox-nav-{{ ai_gen_id }} ai-timeline-lightbox-prev-{{ ai_gen_id }}" aria-label="Previous image">&lsaquo;</button>
    <div class="ai-timeline-lightbox-content-{{ ai_gen_id }}">
      <img src="" alt="" id="lightbox-image-{{ ai_gen_id }}">
    </div>
    <button class="ai-timeline-lightbox-nav-{{ ai_gen_id }} ai-timeline-lightbox-next-{{ ai_gen_id }}" aria-label="Next image">&rsaquo;</button>
  </div>
</timeline-block-{{ ai_gen_id }}>

<script>
  (function() {
    class TimelineBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentImages = [];
        this.currentIndex = 0;
      }

      connectedCallback() {
        this.lightbox = this.querySelector('#lightbox-{{ ai_gen_id }}');
        this.lightboxImage = this.querySelector('#lightbox-image-{{ ai_gen_id }}');
        this.closeBtn = this.querySelector('.ai-timeline-lightbox-close-{{ ai_gen_id }}');
        this.prevBtn = this.querySelector('.ai-timeline-lightbox-prev-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('.ai-timeline-lightbox-next-{{ ai_gen_id }}');
        this.galleryItems = this.querySelectorAll('.ai-timeline-gallery-item-{{ ai_gen_id }}');

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.galleryItems.forEach((item) => {
          item.addEventListener('click', (e) => {
            const eventId = item.getAttribute('data-event-id');
            const imageIndex = parseInt(item.getAttribute('data-image-index'));
            this.openLightbox(eventId, imageIndex);
          });
        });

        this.closeBtn.addEventListener('click', () => this.closeLightbox());
        this.prevBtn.addEventListener('click', () => this.navigateImage(-1));
        this.nextBtn.addEventListener('click', () => this.navigateImage(1));

        this.lightbox.addEventListener('click', (e) => {
          if (e.target === this.lightbox) {
            this.closeLightbox();
          }
        });

        document.addEventListener('keydown', (e) => {
          if (this.lightbox.classList.contains('active')) {
            if (e.key === 'Escape') {
              this.closeLightbox();
            } else if (e.key === 'ArrowLeft') {
              this.navigateImage(-1);
            } else if (e.key === 'ArrowRight') {
              this.navigateImage(1);
            }
          }
        });
      }

      openLightbox(eventId, imageIndex) {
        const eventItems = this.querySelectorAll(`.ai-timeline-gallery-item-{{ ai_gen_id }}[data-event-id="${eventId}"]`);
        this.currentImages = Array.from(eventItems).map(item => {
          const img = item.querySelector('img');
          return {
            src: img.src.replace(/width=\d+/, 'width=1200'),
            alt: img.alt
          };
        });

        this.currentIndex = imageIndex;
        this.updateLightboxImage();
        this.lightbox.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      closeLightbox() {
        this.lightbox.classList.remove('active');
        document.body.style.overflow = '';
      }

      navigateImage(direction) {
        this.currentIndex = (this.currentIndex + direction + this.currentImages.length) % this.currentImages.length;
        this.updateLightboxImage();
      }

      updateLightboxImage() {
        if (this.currentImages.length > 0) {
          const currentImage = this.currentImages[this.currentIndex];
          this.lightboxImage.src = currentImage.src;
          this.lightboxImage.alt = currentImage.alt;
        }
      }
    }

    customElements.define('timeline-block-{{ ai_gen_id }}', TimelineBlock{{ ai_gen_id }});
  })();
</script>

